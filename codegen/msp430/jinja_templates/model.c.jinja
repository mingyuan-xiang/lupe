#include <libdsp/DSPLib.h>
#include <libmatAbstract/mat.h>
#include <libmsp/mspbase.h>
#include <libmspdriver/driverlib.h>
#include <msp430.h>

{% for layer in layer_list -%}
#include <include/{{ layer }}_compute.h>
#include <include/{{ layer }}_param.h>
{% endfor %}

uint16_t {{ model_name }}(mat_t* image) {
  uint16_t pos;
  {#- Prepare the input data #}
  memcpy(in_meta.data, image->data, MAT_GET_SIZE(image)*sizeof(uint16_t));
  {# layers #}
  {%- for layer in layer_list %}
  /* {{ layer }} */
  memset({{ layer }}_out_meta.data, 0, MAT_GET_SIZE(&{{ layer }}_out_meta)*sizeof(uint16_t));
  {{ layer }}(&{{ layer }}_in_meta, &{{ layer }}_weight_meta, &{{ layer }}_bias_meta, &{{ layer }}_out_meta);
  {% endfor %}

  {#- classification #}
  /* Get the max score */
  uint16_t max = 0;
  for (uint16_t i = 0; i < {{ last_layer }}_out_meta.dims[1]; ++i) {
    max = {{ last_layer }}_out_meta.data[max] > {{ last_layer }}_out_meta.data[i] ? max : i;
  }

  return max;
}