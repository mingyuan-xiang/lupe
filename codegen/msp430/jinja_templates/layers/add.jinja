#include <buffer/include/add_buffer.h>

{%- if lea_opt %}
static inline void new_add_q15(const _q15* srcA, const _q15* srcB, _q15* dst) {
  lea_add_params->input2 = MSP_LEA_CONVERT_ADDRESS(srcB);
  lea_add_params->output = MSP_LEA_CONVERT_ADDRESS(dst);

  /* Load source arguments to LEA. */
  LEAPMS0 = MSP_LEA_CONVERT_ADDRESS(srcA);
  LEAPMS1 = MSP_LEA_CONVERT_ADDRESS(lea_add_params);

  /* Invoke the LEACMD__ADDMATRIX command. */
  msp_lea_invokeCommand(LEACMD__ADDMATRIX);
}
{%- endif %}

void {{ layer_name }}(mat_t* input, mat_t* output) {
  uint16_t input_size = input->strides[0];
  uint16_t lea_line_size = LEA_SRC_SIZE;
  uint16_t lea_line_size_cnt = input_size / lea_line_size;
  uint32_t lea_line_size_offset = lea_line_size*sizeof(int16_t);
  uint16_t lea_input_line_remain_size = input_size % lea_line_size;;
  uint32_t lea_input_line_remain_size_offset = lea_input_line_remain_size*sizeof(int16_t);

  uint32_t input_0_fram_addr = (uint32_t){{ layer_name }}_add_buffer_meta.data;
  uint32_t input_1_fram_addr = (uint32_t)input->data;
  uint32_t output_fram_addr = (uint32_t)output->data;

  {% if lea_opt %}
  add_init(MAKE_ALIGN_2(lea_input_line_remain_size));
  {%- else %}
  msp_add_q15_params add_params = { .length = MAKE_ALIGN_2(lea_input_line_remain_size) };
  {%- endif %}

  /*
  * Do the remaining size ADD when the input size is not a multiple
  * of the lea buffer size
  */
  {%- if (input_size % lea_src_size) != 0 %}
  DMA_makeTransfer(input_0_fram_addr, (uint32_t)lea_src, lea_input_line_remain_size);
  DMA_makeTransfer(input_1_fram_addr, (uint32_t)lea_tmp, lea_input_line_remain_size);
  {%- if lea_opt %}
  new_add_q15(lea_src, lea_tmp, lea_dst);
  {%- else %}
  msp_add_q15(&add_params, lea_src, lea_tmp, lea_dst);
  {%- endif %}
  DMA_makeTransfer((uint32_t)lea_dst, output_fram_addr, lea_input_line_remain_size);

  input_0_fram_addr += lea_input_line_remain_size_offset;
  input_1_fram_addr += lea_input_line_remain_size_offset;
  output_fram_addr += lea_input_line_remain_size_offset;
  {%- endif %}

  {%- if input_size >= lea_src_size %}

  /* Compute the rest ADD */
  {%- if lea_opt %}
  lea_add_params->vectorSize = MAKE_ALIGN_2(lea_line_size);
  {%- else %}
  add_params.length = MAKE_ALIGN_2(lea_line_size);
  {%- endif %}
  for (uint16_t l = 0; l < lea_line_size_cnt; ++l) {
    DMA_makeTransfer(input_0_fram_addr, (uint32_t)lea_src, lea_line_size);
    DMA_makeTransfer(input_1_fram_addr, (uint32_t)lea_tmp, lea_line_size);
    {%- if lea_opt %}
    new_add_q15(lea_src, lea_tmp, lea_dst);
    {%- else %}
    msp_add_q15(&add_params, lea_src, lea_tmp, lea_dst);
    {%- endif %}
    DMA_makeTransfer((uint32_t)lea_dst, output_fram_addr, lea_line_size);

    input_0_fram_addr += lea_line_size_offset;
    input_1_fram_addr += lea_line_size_offset;
    output_fram_addr += lea_line_size_offset;
  }
  {%- endif %}

  {%- if lea_opt %}
  add_clear();
  {%- endif %}
}